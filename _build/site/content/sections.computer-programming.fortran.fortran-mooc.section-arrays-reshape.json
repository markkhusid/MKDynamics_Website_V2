\n\ncontains\n\n    subroutine print_matrix(A)\n        implicit none\n        integer, dimension(:, :), intent(in) :: A\n        integer :: i\n\n        do i = 1, size(A, 1)\n            print *, A(i, :)\n        end do\n    end subroutine print_matrix\n\nend program reshape_test","position":{"start":{"line":1,"column":1},"end":{"line":29,"column":1}},"key":"RoXYqAqhVv"}],"key":"T80uGgTlMP"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"RQtce6mKgL"}],"key":"OLh8VfgHqe"}],"key":"MGkK0hktdx"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Build the Program using FPM (Fortran Package Manager)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"yaZ1EsB1kg"}],"identifier":"build-the-program-using-fpm-fortran-package-manager","label":"Build the Program using FPM (Fortran Package Manager)","html_id":"build-the-program-using-fpm-fortran-package-manager","implicit":true,"key":"ocXmYB3aAV"}],"key":"zs3PIcnMTV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"N8UQSUUZmz"},{"type":"outputs","id":"qomrOmzsorNatY1b5QYGH","children":[],"key":"auB3oBc3YG"}],"key":"twLU2wGAQV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Fortran_Code/Section_Arrays_Reshape\"","key":"hzCuftLVnr"},{"type":"outputs","id":"z8Nq6Cx_ab3F59uQDj_os","children":[],"key":"sNrAXdAuUe"}],"key":"e2atrjMn0V"},{"type":"block","kind":"notebook-code","children":[{"type"