mn":1},"end":{"line":1,"column":1}},"key":"b6DMksV0Wx"}],"identifier":"program-that-demonstrates-pointer-types-in-c","label":"Program that demonstrates pointer types in C++","html_id":"program-that-demonstrates-pointer-types-in-c","implicit":true,"key":"aqusSVELE2"}],"key":"SFzccIPANQ"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"cpp","value":"// Pointer - based call - by - reference\n#include <iostream>\n\nusing namespace std;\n\nvoid order (int *, int *);\n\nint main()\n{\n    int i = 7, j = 3;\n\n    cout << i << '\\t' << j << endl; // 7 3 is printed\n    order(&i, &j);\n    cout << i << '\\t' << j << endl; // 3 7 is printed\n}\n\nvoid order(int * p, int * q)\n{\n    int temp;\n\n    if (*p > *q) {\n        temp = *p;\n        *p = *q;\n        *q = temp;\n    }\n}","key":"TDztjXFGYV"}],"key":"u1hjw1Zy0G"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Compile and Execute the Program","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tapffSjklM"}],"identifier":"compile-and-execute-the-program","label":"Compile and Execute the Program","html_id":"compile-and-execute-the-program","implicit":true,"key":"VzohGwyrHq"}],"key":"Fx1jbNknuS"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"o9RugzDuPv"}],"key":"UOEWvmBpWr"}],"key":"nJHZAZM2a0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"uYK2h2PpxI"},{"type":"outputs","id":"evzQbxIoKZxV0cNGIxXA4","children":[],"key":"DGZEZfN0Kd"}],"key":