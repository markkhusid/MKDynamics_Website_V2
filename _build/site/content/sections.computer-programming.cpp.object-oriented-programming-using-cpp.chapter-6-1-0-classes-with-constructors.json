 v = i % modulus; }\n   void  print() const { cout << v << '\\t'; }\n   const static int modulus = 60;\nprivate:\n   int  v;\n};\n\ninline  mod_int::mod_int(int i = 0)\n{\n    v = i % modulus;\n}\nconst int  mod_int::modulus;\n\nint main()\n{\n   int      seconds = 400;\n   mod_int  z(seconds);\n\n   cout << seconds << \" seconds equals \"\n        << seconds / 60 << \" minutes \";\n   z.print();\n   cout << \" seconds\" << endl;\n}","position":{"start":{"line":1,"column":1},"end":{"line":47,"column":1}},"key":"hCKCi3mGoA"}],"key":"xusMPjKGyE"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tyTsvr3qsw"}],"key":"irt3RMzQUU"}],"key":"FI9zDT4Xur"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"o5AoQfzEfj"},{"type":"outputs","id":"SQz74K0dbkSw8P_eLSJUM","children":[],"key":"nxeT76SrMk"}],"key":"kiC4bwG3Gp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \\\n    \"Cpp_Code/Chapter_6_1_0_Classes_with_Constructors\"","key":"bWUK8mN7Ag"},{"type":"outputs","id":"J-RMBPt_JLks_Syfb_Sma","children":[],"key":"CQ7R2w2slB"}],"key":"StOWYw2ZUd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"q1IssBUH1v"},{"type":"outputs","id":"558k71PYUJj39aGkSBRzI","children":[],"key":"arQLY2bNd4"}],"key":"XDWPSvelKc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ modulo.cpp -w -o modulo\")","key":"TnPNz0CY0a"},{"type":"outputs","id":"pAMied