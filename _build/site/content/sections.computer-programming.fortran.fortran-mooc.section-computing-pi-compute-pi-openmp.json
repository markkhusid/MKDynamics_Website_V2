n class=\"hide-tail\" style=\"min-width:1.02em;height:1.28em;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width='400em' height='1.28em' viewBox='0 0 400000 1296' preserveAspectRatio='xMinYMin slice'><path d='M263,681c0.7,0,18,39.7,52,119\nc34,79.3,68.167,158.7,102.5,238c34.3,79.3,51.8,119.3,52.5,120\nc340,-704.7,510.7,-1060.3,512,-1067\nl0 -0\nc4.7,-7.3,11,-11,19,-11\nH40000v40H1012.3\ns-271.3,567,-271.3,567c-38.7,80.7,-84,175,-136,283c-52,108,-89.167,185.3,-111.5,232\nc-22.3,46.7,-33.8,70.3,-34.5,71c-4.7,4.7,-12.3,7,-23,7s-12,-1,-12,-1\ns-109,-253,-109,-253c-72.7,-168,-109.3,-252,-110,-252c-10.7,8,-22,16.7,-34,26\nc-22,17.3,-33.3,26,-34,26s-26,-26,-26,-26s76,-59,76,-59s76,-60,76,-60z\nM1001 80h400000v40h-400000z'/></svg></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.1795em;\"><span></span></span></span></span></span><span class=\"mord mathnormal sizing reset-size6 size8\">d</span><span class=\"mord mathnormal sizing reset-size6 size8\">x</span></span></span></span></span>","enumerator":"1","key":"upcJvba2Nj"}],"key":"B7tdUFOXoP"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"In file section_computing_pi_compute_pi_openmp.f90","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"r3B6NGnrVW"}],"identifier":"in-file-section-computing-pi-compute-pi-openmp-f90","label":"In file section_computing_pi_compute_pi_openmp.f90","html_id":"in-file-section-computing-pi-compute-pi-openmp-f90","implicit":true,"key":"exuO6W7bda"}],"key":"dfCUGzCHhq"},{"type":"block","kind":"notebook-content","children":[{"type":"include","file":"Fortran_Code/Section_Computing_Pi_Compute_Pi_OpenMP/app/section_computing_pi_compute_pi_openmp.f90","literal":true,"children":[{"type":"code","value":"program compute_pi_omp\n  use, intrinsic :: iso_fortran_env, only : DP => REAL64, I8 => INT64\n  implicit none\n  integer(kind=I8) :: i, nr_iters\n  real(kind=DP) :: delta, x, pi_val\n  real(kind=DP) :: pi_val_actual\n\n  pi_val = 0.0_DP\n  pi_val_actual = 2.0_DP * acos(0.0_DP)\n  nr_iters = get_nr_iters()\n  delta = 1.0_DP/nr_iters\n  x = 0.0_DP\n\n  !$omp parallel do default(none) private(x) shared(delta, nr_iters) reduction(+:pi_val)\n  do i = 1, nr_iters\n      x = i*delta\n      pi_val = pi_val + sqrt(1.0_DP - x**2)\n  end do\n  !$omp end parallel do\n\n  pi_val = 4.0_DP*pi_val/nr_iters\n  print '(A, I15, A, F25.15)', \"After \", nr_iters, \" loops, Pi = \", pi_val\n  print '(A, F25.15)', \"Actual value of Pi = \", pi_val_actual\n  print '(A, F25.15)', \"Absolute difference = \", abs(pi_val - pi_val_actual)\ncontains\n   \n  function get_nr_iters() result(nr_iters)\n      use, intrinsic :: iso_fortran_env, only : error_unit\n      implicit none\n      integer(kind=I8) :: nr_iters\n      integer(kind=I8), parameter :: default_nr_iters = 1000_I8\n      character(len=1024) :: buffer, msg\n      integer :: istat\n\n      if (command_argument_count() >= 1) then\n          call get_command_argument(1, buffer)\n          read (buffer, fmt=*, iostat=istat, iomsg=msg) nr_iters\n          if (istat /= 0) then\n              write (unit=error_unit, fmt='(2A)') &\n                  'error: ', msg\n              stop 1\n          end if\n      else\n          nr_iters = default_nr_iters\n      end if\n  end function get_nr_iters\n\nend program compute_pi_omp\n","lang":"fortran","filename":"section_computing_pi_compute_pi_openmp.f90","key":"UDdYqAD4wO"}],"key":"j27s59nGzd"}],"key":"WuhW8zOKik"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"KiGWfIjEBi"}],"key":"IPUUz5ka8h"}],"key":"LqAnuQ0r0x"},{"type":"block","kind":"notebook-content","data":{"tags":[]},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Build the Program using FPM (Fortran Package Manager)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"rV2XDdp14M"}],"identifier":"build-the-program-using-fpm-fortran-package-manager","label":"Build the Program using FPM (Fortran Package Manager)","html_id":"build-the-program-using-fpm-fortran-package-manager","implicit":true,"key":"m326NpONkA"}],"visibility":"show","key":"WzSss9w12M"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = \"\"\nroot_dir = os.getcwd()","key":"E4Hba6enKN"},{"type":"outputs","id":"v1UTExa9J-IGfjtsucSdO","children":[],"key":"oH1qOXwRmS"}],"key":"AkelRzsXlZ"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Since this program uses the OpenMP external library, the fpm.toml file had to be augmented as below.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"xhxWMG917W"}],"key":"cansIpwj54"}],"key":"HOLFcpSGQG"},{"type":"block","kind":"notebook-content","children":[{"type":"include","file":"Fortran_Code/Section_Computing_Pi_Compute_Pi_OpenMP/fpm.toml","literal":true,"children":[{"type":"code","value":"name = \"Section_Computing_Pi_Compute_Pi_OpenMP\"\n\n[build]\nauto-executables = true\nauto-tests = true\nauto-examples = true\n\n[dependencies]\nopenmp=\"*\"\n\n[install]\nlibrary = false\n\n[[executable]]\nname=\"Section_Computing_Pi_Compute_Pi_OpenMP\"\nsource-dir=\"app\"\nmain=\"section_computing_pi_compute_pi_openmp.f90\"\n","lang":"toml","filename":"fpm.toml","key":"nl6bYdldb7"}],"key":"pxqKbjnZwu"}],"key":"wpaUFI9Z8a"},{"type":"blo