A, F5.1)', 'sqrt(0.0) = ', sqrt(zero)\n    print '(A, F5.1)', 'sqrt(-0.0) = ', sqrt(minus_zero)\nend program zero_vs_minus_zero","position":{"start":{"line":1,"column":1},"end":{"line":18,"column":1}},"key":"L8TraKSx9K"}],"key":"iVDcHuAcds"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gpRnTTG13x"}],"key":"kHhsvcR5ta"}],"key":"kFGeOYx8VB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"JBivJDdMAI"},{"type":"outputs","id":"tEgoEcUiKq6ENF6gYs94y","children":[],"key":"RVmn8zkuJ7"}],"key":"d4ex7jtYBT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Fortran_Code/Section_IEEE754_Zero_vs_Non_Zero\"","key":"VRV7qHsMXL"},{"type":"outputs","id":"-NDg48O8i7Bn8Pvsxu8Ez","children":[],"key":"Ppcg7Mm70E"}],"key":"OyHnOm6Y8W"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"YSBQLFWWt2"},{"type":"outputs","id":"fqusCUBNqNmnWZ4UqmObX","children":[],"key":"bGUZyqa5du"}],"key":"dsSQk3b7NS"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_status = os.system(\"fpm build 2>/dev/null\")","key":"SRe49fRZ9n"},{"type":"outputs","id":"PNJbG2vo3j6Kswaw5ASwO","children":[],"key":"BEumA6nzEB"}],"key":"QVOISIF83a"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"fpm run output is piped into sed to suppress the status of the run command