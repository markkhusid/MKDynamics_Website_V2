{"version":3,"kind":"Notebook","sha256":"4b28d47cff7f5cced993c49c842d1b185b4df6fceccfbda199b157f49e79183d","slug":"sections.computer-programming.cpp.object-oriented-programming-using-cpp.chapter-1-7-the-standard-template-library","location":"/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_1_7_The_Standard_Template_Library.ipynb","dependencies":[],"frontmatter":{"title":"Chapter 1.7: The C++ Standard Template Library","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Mark Khusid","given":"Mark","family":"Khusid"},"name":"Mark Khusid","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/markkhusid/MKDynamics_Website_V2","numbering":{"title":{"offset":5}},"source_url":"https://github.com/markkhusid/MKDynamics_Website_V2/blob/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_1_7_The_Standard_Template_Library.ipynb","edit_url":"https://github.com/markkhusid/MKDynamics_Website_V2/edit/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_1_7_The_Standard_Template_Library.ipynb","exports":[{"format":"ipynb","filename":"Chapter_1_7_The_Standard_Template_Library.ipynb","url":"/Chapter_1_7_The_Stan-3402d3e87342a1f4c6519921c43384d5.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Adapted from: “Object-Oriented Programming Using C++” by Ira Pohl (Addison- Wesley)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Hz3OGJmAST"}],"key":"MqWMqd7DeI"}],"key":"MWnGqdTcyp"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Program that demonstrates use of the C++ Standard Template Library","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"vTUIehNrEJ"}],"identifier":"program-that-demonstrates-use-of-the-c-standard-template-library","label":"Program that demonstrates use of the C++ Standard Template Library","html_id":"program-that-demonstrates-use-of-the-c-standard-template-library","implicit":true,"key":"XuyuUo7EPW"},{"type":"code","lang":"cpp","value":"// Using the list container.\n#include <iostream>\n#include <list>\n#include <numeric>\nusing namespace std;\n\nvoid print(const list<double> &lst)\n{ // using an iterator to traverse lst\n    list<double>::const_iterator where;\n\n    for(where = lst.begin(); where != lst.end(); ++where)\n        cout << *where << '\\t';\n    cout << endl;\n}\n\nint main()\n{\n    double w[4] = {0.9, 0.8, 88, -99.99};\n    list<double> z;\n\n    for (int i = 0; i < 4; ++i)\n        z.push_front(w[i]);\n    print(z);\n    z.sort();\n    print(z);\n    cout << \"sum is \" << accumulate(z.begin(), z.end(), 0.0) << endl;\n}","key":"GXKgnUNTQH"}],"key":"GGmeb84N2a"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wabKnLDXx6"}],"key":"eWUDIZqHhG"}],"key":"VsHzdVQgZs"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"KgbBqOLJTU"},{"type":"outputs","id":"FTkzFclqzGX9t-TYSypiM","children":[],"key":"kC12mjLsNf"}],"key":"guCTunwcUj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Cpp_Code/Chapter_1_7_The_Standard_Template_Library\"","key":"nUiyHuCK4T"},{"type":"outputs","id":"WbLtxtOYSWx6WStT5A45k","children":[],"key":"mNIbUoeM0J"}],"key":"LeGWrSok4k"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"OyV0DOSNsO"},{"type":"outputs","id":"1uz2FOaK7NTGDfclOtCmH","children":[],"key":"LTdClD7azN"}],"key":"BmBgGQO2Mt"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ stl_list.cpp -w -o stl_list\")","key":"SwOOrDNU5H"},{"type":"outputs","id":"7_nbjHNA2eWWtUNSU9ESi","children":[],"key":"uJU0pekBov"}],"key":"zo9tyDAqfb"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"exec_status = os.system(\"./stl_list\")","key":"WqZpJ2LzVX"},{"type":"outputs","id":"wRvkpKiXPwxRczdT-AaGE","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"-99.99\t88\t0.8\t0.9\t\n-99.99\t0.8\t0.9\t88\t\nsum is -10.29\n"},"children":[],"key":"p2Jf1zpoRa"}],"key":"vtFnj7bUWz"}],"key":"dTVog6Ab3Z"}],"key":"qJPGLhVazn"},"references":{"cite":{"order":[],"data":{}}}}