 total\nend program matrix","position":{"start":{"line":1,"column":1},"end":{"line":22,"column":1}},"key":"pe0tMapyBA"}],"key":"LOYRsbFG96"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"aQgNX10wGi"}],"key":"M4FXgL5mhv"}],"key":"QiuvGhLfIu"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Build the Program using FPM (Fortran Package Manager)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ivvd8ysMys"}],"identifier":"build-the-program-using-fpm-fortran-package-manager","label":"Build the Program using FPM (Fortran Package Manager)","html_id":"build-the-program-using-fpm-fortran-package-manager","implicit":true,"key":"LYSh9Un0mM"}],"key":"jYFiBxofHg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"OR6dBbDMvw"},{"type":"outputs","id":"ngzy8-t3DTTUjG03wdKEu","children":[],"key":"uBfQbMMi0B"}],"key":"B7ICSe37yN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Fortran_Code/Section_Arrays_Matrix\"","key":"WNM6YtpB5C"},{"type":"outputs","id":"ugPSQbLrOL7sUYCLckpOb","children":[],"key":"kxdcteOdyL"}],"key":"WwK9V2DkXa"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"lqBCmleQ4l"},{"type":"outputs","id":"SJq24tgaY9udkVI2VkQt2","children":[],"key":"utfKunU8co"}],"key":"sW4kNOsR4q"},{"type":"block","kind":"notebook-code","children":[{"type":"cod