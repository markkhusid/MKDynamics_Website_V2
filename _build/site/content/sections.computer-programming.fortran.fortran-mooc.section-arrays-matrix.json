 total\nend program matrix","position":{"start":{"line":1,"column":1},"end":{"line":22,"column":1}},"key":"voKUyIzsbf"}],"key":"ZDYVlvTOUJ"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cWuG5UxF4b"}],"key":"HFLkCzskKd"}],"key":"nOfu0BnrGW"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Build the Program using FPM (Fortran Package Manager)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gHhgi7uHi5"}],"identifier":"build-the-program-using-fpm-fortran-package-manager","label":"Build the Program using FPM (Fortran Package Manager)","html_id":"build-the-program-using-fpm-fortran-package-manager","implicit":true,"key":"jF7pJXmm9x"}],"key":"nvXe2wKZ8n"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"jeNV0luiLi"},{"type":"outputs","id":"p-8nM7Mjf-0bloKPAqTjM","children":[],"key":"gVk2euEzQ2"}],"key":"yGS6CHiVxT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Fortran_Code/Section_Arrays_Matrix\"","key":"w0dyVYpDu9"},{"type":"outputs","id":"JJSQTKcShFboSAfp183S5","children":[],"key":"BVajV62KoR"}],"key":"DkA7Uj54Nc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"TGF6v8gOax"},{"type":"outputs","id":"Cwv_8epBvlHjXYPdSmGqE","children":[],"key":"grp9BgybC8"}],"key":"P11aH0LXRR"},{"type":"block","kind":"notebook-code","children":[{"type":"cod