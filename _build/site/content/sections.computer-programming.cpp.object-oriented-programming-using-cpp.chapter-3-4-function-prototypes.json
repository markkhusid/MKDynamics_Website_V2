{"version":3,"kind":"Notebook","sha256":"0825e85956adcccb4a746a6acb3799aad54687332bb41c7211375f3bae7f2794","slug":"sections.computer-programming.cpp.object-oriented-programming-using-cpp.chapter-3-4-function-prototypes","location":"/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_3_4_Function_Prototypes.ipynb","dependencies":[],"frontmatter":{"title":"Chapter 3.4: Function Prototypes","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Mark Khusid","given":"Mark","family":"Khusid"},"name":"Mark Khusid","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/markkhusid/MKDynamics_Website_V2","numbering":{"title":{"offset":5}},"source_url":"https://github.com/markkhusid/MKDynamics_Website_V2/blob/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_3_4_Function_Prototypes.ipynb","edit_url":"https://github.com/markkhusid/MKDynamics_Website_V2/edit/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_3_4_Function_Prototypes.ipynb","exports":[{"format":"ipynb","filename":"Chapter_3_4_Function_Prototypes.ipynb","url":"/Chapter_3_4_Function-f65a59a91df08e2810f145c0dd96a990.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Adapted from: “Object-Oriented Programming Using C++” by Ira Pohl (Addison- Wesley)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ITdlwprxTF"}],"key":"Z4wtvUMxyx"}],"key":"PAe4m6s4tG"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Program that demonstrates function prototypes in C++","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XLPSv8jSgD"}],"identifier":"program-that-demonstrates-function-prototypes-in-c","label":"Program that demonstrates function prototypes in C++","html_id":"program-that-demonstrates-function-prototypes-in-c","implicit":true,"key":"XF0Uxh4tAY"}],"key":"fxI884ptC0"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"cpp","value":"// Add three ints - illustrating function prototypes\n#include <iostream>\n\nint add3(int, int, int);\ndouble average(int);\n\nusing namespace std;\n\nint main()\n{\n    int score_1, score_2, score_3, sum;\n\n    cout << \"\\nEnter 3 scores: \";\n    cin >> score_1 >> score_2 >> score_3;\n    sum = add3(score_1, score_2, score_3);\n    cout << \"\\nTheir sum is \" << sum;\n    cout << \"\\nTheir average is \" << average(sum);\n    sum = add3(1.5 * score_1, score_2, 0.5 * score_3);\n    cout << \"\\nTheir weighted sum is \" << sum << \".\";\n    cout << \"\\nTheir weighted average is \" << average(sum) << \".\" << endl;\n}\n\nint add3(int a, int b, int c)\n{\n    return (a + b + c);\n}\n\ndouble average(int s)\n{\n    return (s / 3.0);\n}","key":"SdfReSTWHi"}],"key":"m7EEh00vUA"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Compile and Execute the Program","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"QMNEIp1dDx"}],"identifier":"compile-and-execute-the-program","label":"Compile and Execute the Program","html_id":"compile-and-execute-the-program","implicit":true,"key":"hdyJbunZ0f"}],"key":"cTQz5eKsf2"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"sta