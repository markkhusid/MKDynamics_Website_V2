 1, 3\n        print '(*(F7.2))', B(i, :)\n    end do\n\n    print '(A)', 'C'\n    do i = 1, 3\n        print '(*(F7.2))', C(i, :)\n    end do\n\ncontains\n\n    elemental subroutine compute(A, B, C)\n        implicit none\n        real, intent(in) :: A\n        real, intent(out) :: B\n        real, intent(out) :: C\n\n        B = 2*A\n        C = 3*A\n    end subroutine compute\n\nend program elemental_subroutine","position":{"start":{"line":1,"column":1},"end":{"line":37,"column":1}},"key":"V57BGSc6xN"}],"key":"HaNgYYHEeD"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"X5smgxlKnZ"}],"key":"RmduN3aZcX"}],"key":"Q8QfC14EzM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"W85yawhcTq"},{"type":"outputs","id":"zlk9-n-k3m4C4QsjpIoSP","children":[],"key":"JBNdsw5Uvf"}],"key":"zY2zyd0Bn2"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Fortran_Code/Section_Arrays_Elemental_Subroutine\"","key":"FChesNEBNt"},{"type":"outputs","id":"_edHoc4ENzpi-dcNfU5Ye","children":[],"key":"fzNyeXwHOH"}],"key":"T4WNvzWq0r"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"u7mIbpofMC"},{"type":"outputs","id":"lrXYpL3V33JQgBRxp7mCu","children":[],"key":"gbDbDN1s2W"}],"key":"XzOmcHA8iR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_status = os.system(\"fpm build 2>/dev/null\")","key":"zEzwIwDcKU"},{"type":"outputs","id":"IY1xcQTyhhkVf-eu1iKMk","children":[],"ke