\n  vector2 = 0.0\n  call scopy(size(vector1), vector1, 2, vector2, 2)\n  print '(A20, *(F5.1))', 'copy N 2 2: ', vector2\n\n  large_vector = 0.0\n  call scopy(size(vector1), vector1, 1, large_vector, 2)\n  print '(A20, *(F5.1))', 'copy N 1 2: ', large_vector\n  call scopy(size(vector1), 3.0*vector1, 1, large_vector(2), 2)\n  print '(A20, *(F5.1))', 'shift copy N 1 2: ', large_vector\n\nend program copy_test\n","lang":"fortran","filename":"section_blas_lapack_copy.f90","key":"j4bEWcuQal"}],"key":"Ub1QB6Gnyd"}],"key":"om0lwZqKqS"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Yr9YLZLzAZ"}],"key":"pwgb3hngCi"}],"key":"UmTrYCOngP"},{"type":"block","kind":"notebook-content","data":{"tags":[]},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Build the Program using FPM (Fortran Package Manager)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"CCuECyXKWV"}],"identifier":"build-the-program-using-fpm-fortran-package-manager","label":"Build the Program using FPM (Fortran Package Manager)","html_id":"build-the-program-using-fpm-fortran-package-manager","implicit":true,"key":"yDUbfg89ec"}],"visibility":"show","key":"HzCVK5e490"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = \"\"\nroot_dir = os.getcwd()","key":"k1A5TZAFuv"},{"type":"outputs","id":"-qXnC_mEJUwaavTtXLxZV","children":[],"key":"qECjBuxofR"}],"key":"dhgJs5RihF"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type"