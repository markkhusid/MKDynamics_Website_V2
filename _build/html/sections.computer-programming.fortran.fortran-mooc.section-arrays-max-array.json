he-maxval-and-maxloc-intrinsic-functions-in-fortran","label":"This program demonstrates the maxval and maxloc intrinsic functions in Fortran.","html_id":"this-program-demonstrates-the-maxval-and-maxloc-intrinsic-functions-in-fortran","implicit":true,"key":"Wv0WhceCBd"}],"key":"Okk9vrsCbX"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"fortran","value":"program max_array\n    implicit none\n    integer, dimension(3, 4) :: A\n    integer :: i, j\n    character(len=10), parameter :: FMT = '(A, 4I13)'\n\n    A = reshape (  [ &\n                    ( &\n                      ((i - 1)*size(A, 2) + j, &\n                        j=1,size(A, 2)), &\n                        i=1,size(A, 1) &\n                    ) &\n                  ], &\n                  shape(A) &\n                ) - 8\n\n    ! Print out array\n    do i = 1, size(A, 1)\n        print *, A(i, :)\n    end do\n\n    print *\n\n    print FMT, 'maximum =                       ', maxval(A)\n    print FMT, 'row maximum =                   ', maxval(A, dim=1)\n    print FMT, 'column maximum =                ', maxval(A, dim=2)\n    print FMT, 'maximum odd elment =            ', maxval(A, mask=mod(A, 2) /= 0)\n    print FMT, 'row maximum negative element =  ', maxval(A, dim=2, mask=A < 0)\n    print FMT, 'maxloc (row, col) =             ', maxloc(A)\n    print FMT, 'column maxloc (columns) =       ', maxloc(A, dim=2)\nend program max_array","position":{"start":{"line":1,"column":1},"end":{"line":33,"column":1}},"key":"FBoAd5CbbV"}],"key":"a3rk0nMdtD"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"s94MVYE0Ik"}],"key":"I5aR9eLw5m"}],"key":"SNQkZN2OFt"},{"type":"block","kind":"notebook-content","childr