{"version":3,"kind":"Notebook","sha256":"7df281f6551038a95fc3a9ddb9a33e50c273da98c564c032f30d5ebf12fcf79c","slug":"sections.computer-programming.cpp.object-oriented-programming-using-cpp.chapter-3-16-assertions-and-program-correctness","location":"/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_3_16_Assertions_and_Program_Correctness.ipynb","dependencies":[],"frontmatter":{"title":"Chapter 3.16: Assertions and Program Correctness","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Mark Khusid","given":"Mark","family":"Khusid"},"name":"Mark Khusid","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/markkhusid/MKDynamics_Website_V2","numbering":{"title":{"offset":5}},"source_url":"https://github.com/markkhusid/MKDynamics_Website_V2/blob/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_3_16_Assertions_and_Program_Correctness.ipynb","edit_url":"https://github.com/markkhusid/MKDynamics_Website_V2/edit/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_3_16_Assertions_and_Program_Correctness.ipynb","exports":[{"format":"ipynb","filename":"Chapter_3_16_Assertions_and_Program_Correctness.ipynb","url":"/build/Chapter_3_16_Asserti-df5771edded3c14eb5e56fee44fc0d90.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Adapted from: “Object-Oriented Programming Using C++” by Ira Pohl (Addison- Wesley)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nwDHS2eeOp"}],"key":"DdZhoyQ9cy"}],"key":"ydn4YDXGfE"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Program that demonstrates the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"BQA3I8QmA2"},{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"ASSERT","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kHC2Scl0n1"}],"key":"t5XrnOAK8T"},{"type":"text","value":" statement in C++","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"pDdtp3z176"}],"identifier":"program-that-demonstrates-the-assert-statement-in-c","label":"Program that demonstrates the ASSERT statement in C++","html_id":"program-that-demonstrates-the-assert-statement-in-c","implicit":true,"key":"SPGlKEWL2m"}],"key":"uRX2k0j7Uo"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"cpp","value":"// Finding a minimum element in an array slice.\n#include <iostream>\n#include <assert.h>\n\nusing namespace std;\n\nvoid order (int & p, int & q)\n{\n    int temp = p;\n    if (p > q) {\n        p = q;\n        q = temp;\n    }\n}\n\nint place_min(int a[], int size, int lb = 0)\n{\n    int i, min;\n    assert(size >= 0);   // precondition\n\n    for (i = lb; i < lb + size; ++i)\n        order(a[lb], a[i + 1]);\n    return a[lb];\n}\n\nint main()\n{\n    int a[9] = { 6, -9, 99, 3, -14, 9, -33, 8, 11 };\n\n    cout << \"Minimum = \" << place_min(a, 3, 2) << endl;\n    assert(a[2] <= a[3] && a[2] <= a[4]);   // postcondition\n}","key":"GOCl41Y7ia"}],"key":"GygZmNZ04e"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Compile and Execute the Program","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Hq7XVL5sXX"}],"identifier":"compile-and-execute-the-program","label":"Compile and Execute the Program","html_id":"compile-and-execute-the-program","implicit":true,"key":"BUqwmLf70D"}],"key":"iEYGa54Ioo"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nqUnKuhNDJ"}],"key":"YGUAVS8ZRx"}],"key":"EfJ0yGhLjj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"Em2H9Y8evz"},{"type":"outputs","id":"I7zoPYZYVkpiD91zlyJGd","children":[],"key":"gNQJAWWemN"}],"key":"Hiz2M22liT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Cpp_Code/Chapter_3_16_Assertions_and_Program_Correctness\"","key":"DUfTiq2RuH"},{"type":"outputs","id":"3F0LHl_RDKcivTNf_XH5L","children":[],"key":"H4IkQVtcl5"}],"key":"TgnMzMZn4v"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ch_dir_stat = os.chdir(code_dir)","key":"pEj9mNic1O"},{"type":"outputs","id":"iM-PMgYpwd2RmXMr3G3y1","children":[],"key":"XKJIiVG4qc"}],"key":"FCMiWGR6Zd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ order.cpp -w -o order\")","key":"J6tmQDc5p9"},{"type":"outputs","id":"_RebogtAsktwRvdAShbFn","children":[],"key":"ADnbiFNWw9"}],"key":"JB5N9Dq2Wm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"exec_status = os.system(\"./order\")","key":"PM6dvEoiNs"},{"type":"outputs","id":"StLNwyTWuNfg0e7yCjdVA","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Minimum = -14\n"},"children":[],"key":"vnkHztarDj"}],"key":"L9RS2JDAsD"}],"key":"lE2q