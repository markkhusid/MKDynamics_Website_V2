t i) { v = i % modulus; }\n   void  print() const { cout << v << '\\t'; }\n   const static int modulus = 60;\nprivate:\n   int  v;\n};\n\ninline  mod_int::mod_int(int i = 0)\n{\n    v = i % modulus;\n}\nconst int  mod_int::modulus;\n\nint main()\n{\n   int      seconds = 400;\n   mod_int  z(seconds);\n\n   cout << seconds << \" seconds equals \"\n        << seconds / 60 << \" minutes \";\n   z.print();\n   cout << \" seconds\" << endl;\n}","position":{"start":{"line":1,"column":1},"end":{"line":47,"column":1}},"key":"pjkefJLgMu"}],"key":"Rg3anCEo4u"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hMsfajlGoA"}],"key":"Ydn5POQkJc"}],"key":"QL49hyq32o"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"QzAS8gm81q"},{"type":"outputs","id":"tUT6UZ9LNi28SlhrVUi9u","children":[],"key":"rQvyovPr45"}],"key":"nmvWWkgfzz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \\\n    \"Cpp_Code/Chapter_6_1_0_Classes_with_Constructors\"","key":"zEcKRQ4SZJ"},{"type":"outputs","id":"-RUetuR316yiptOAD2Kvl","children":[],"key":"i6OW5NShfR"}],"key":"UzbJvjvwIJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"kGut6XeTXY"},{"type":"outputs","id":"UZRkNEEU_OTM5PRs-nR8W","children":[],"key":"RzBt3MyENK"}],"key":"WRtvbxIFwR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ modulo.cpp -w -o modulo\")","key":"ZYmzfGYjor"},{"type":"outputs","id":"