t i) { v = i % modulus; }\n   void  print() const { cout << v << '\\t'; }\n   const static int modulus = 60;\nprivate:\n   int  v;\n};\n\ninline  mod_int::mod_int(int i = 0)\n{\n    v = i % modulus;\n}\nconst int  mod_int::modulus;\n\nint main()\n{\n   int      seconds = 400;\n   mod_int  z(seconds);\n\n   cout << seconds << \" seconds equals \"\n        << seconds / 60 << \" minutes \";\n   z.print();\n   cout << \" seconds\" << endl;\n}","position":{"start":{"line":1,"column":1},"end":{"line":47,"column":1}},"key":"Jwh9EZ4R08"}],"key":"fn1UK0yLo9"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"XZmljDfDVn"}],"key":"SVMaTF5cPV"}],"key":"w0LN5it4ph"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"XYUBYlIaWO"},{"type":"outputs","id":"hIsUrAB6iHhSJ5Dz9PJv2","children":[],"key":"rWWitaDHWF"}],"key":"eP6EalPSHx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \\\n    \"Cpp_Code/Chapter_6_1_0_Classes_with_Constructors\"","key":"ftjiFjACUm"},{"type":"outputs","id":"34SpJMenr0VXapMyBBpC-","children":[],"key":"tQXc3J4RBi"}],"key":"vdLfqJ8GmC"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"ruAcI1nPQN"},{"type":"outputs","id":"E8PkEGlFAzhN5GMi_sIA1","children":[],"key":"ijXLSzLYbg"}],"key":"kTIQLaoAaH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ modulo.cpp -w -o modulo\")","key":"EdR8F2cF9q"},{"type":"outputs","id":"