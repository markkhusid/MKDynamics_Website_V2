tart":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"CONST","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Gw5Lvn8rfJ"}],"key":"VRJfIHYVKk"},{"type":"text","value":" member functions in C++","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"l6cdAyu7zw"}],"identifier":"program-that-demonstrates-the-static-and-const-member-functions-in-c","label":"Program that demonstrates the STATIC and CONST member functions in C++","html_id":"program-that-demonstrates-the-static-and-const-member-functions-in-c","implicit":true,"key":"QRfP2ZCt16"}],"key":"yTnGO4klKc"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"c++","value":"#include <iostream>\n\nusing namespace std;\n\n// Calculate salary using static members\nclass salary {\npublic:\n    void init(int b) {\n        b_sal = b;\n        your_bonus = 0;\n    }\n\n    void calc_bonus(double perc) {\n        your_bonus = b_sal * perc;\n    }\n\n    static void reset_all(int p) {\n        all_bonus = p;\n    }\n\n    int comp_tot() const {\n        return (b_sal + your_bonus + all_bonus);\n    }\n\nprivate:\n    int         b_sal;\n    int         your_bonus;\n    static int  all_bonus;      // declaration\n};\n\n// declaration and definition\nint salary::all_bonus = 100;\n\nint main() {\n    salary w1, w2;\n\n    w1.init(1000);\n    w2.init(2000);\n\n    w1.calc_bonus(0.2);\n    w2.calc_bonus(0.15);\n\n    salary::reset_all(400);\n\n    cout    << \" w1 \"\n            << w1.comp_tot() \n            << \" w2 \" \n            << w2.comp_tot() \n            << endl;\n}","position":{"start":{"line":1,"column":1},"end":{"line":52,"column":1}},"key":"GdUOWy99tc"}],"key":"fNeKbq2TjL"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tFC4oESQiR"}],"key":"OgGHlZJ4Ug"}],"key":"inM6eTYhZf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"KNF9iQMSiQ"},{"type":"outputs","id":"n70KbG_mrNmHv3O3E7kco","children":[],"key":"qdg5ol8CAe"}],"key":"wnPFiLLNzP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Cpp_Code/Chapter_5_8_Static_and_Const_Member_Functions\"","key":"wCTTuyNuPZ"},{"type":"outputs","id":"bt_ecNi26iUOQ6wUB01Lq","children":[],"key":"O5FuDz9gHz"}],"key":"VH7K88aJ4Z"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"LFMrtO1HeO"},{"type":"outputs","id":"cwGTrqXF2ZSrlSUsF2GIF","children":[],"key":"r4RgfhlMKh"}],"key":"GCByrztwxl"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ salary.cpp -w -o salary\")","key":"JCJfEItbvX"},{"type":"outputs","id":"MIh-KkTkt7cwc-IyNnW6M","children":[],"key":"FdrApBH2oa"}],"key":"hAEsdwsAQT"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"exec_status = os.system(\"./salary\")","key":"GqOxrSjC4c"},{"type":"outputs","id":"GJacYXDB5d73HlL3GE_Df","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":" w1 1600 w2 2700\n"},"children":[],"key":"v8rOw0fi0y"}],"key":"rsoyc9ceXm"}],"key":"y3rkw1RN9z"}],"key":"g4kuPzrFr9"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"The THIS Pointer","url":"/sections/computer-programming/cpp/object-oriented-programming-using-cpp/chapter-5-7-the-this-pointer","group":"Computer Programming"},"next":{"title":"Containers and Item Acc