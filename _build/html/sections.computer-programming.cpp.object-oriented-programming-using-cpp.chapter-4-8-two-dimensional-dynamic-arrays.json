{"version":3,"kind":"Notebook","sha256":"12d4e974c7dc42b557f3301c872557f731b944833c9a7b186ac46f3e77210351","slug":"sections.computer-programming.cpp.object-oriented-programming-using-cpp.chapter-4-8-two-dimensional-dynamic-arrays","location":"/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_4_8_Two_Dimensional_Dynamic_Arrays.ipynb","dependencies":[],"frontmatter":{"title":"Two Dimensional Dynamic Arrays","content_includes_title":true,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Mark Khusid","given":"Mark","family":"Khusid"},"name":"Mark Khusid","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/markkhusid/MKDynamics_Website_V2","numbering":{"title":{"offset":5}},"source_url":"https://github.com/markkhusid/MKDynamics_Website_V2/blob/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_4_8_Two_Dimensional_Dynamic_Arrays.ipynb","edit_url":"https://github.com/markkhusid/MKDynamics_Website_V2/edit/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_4_8_Two_Dimensional_Dynamic_Arrays.ipynb","exports":[{"format":"ipynb","filename":"Chapter_4_8_Two_Dimensional_Dynamic_Arrays.ipynb","url":"/build/Chapter_4_8_Two_Dime-dc82b2d328b3ca2836a95bd869c6c52e.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"","value":"---\njupytext:\n  formats: md:myst\n  text_representation:\n    extension: .md\n    format_name: myst\nkernelspec:\n  display_name: Python 3\n  language: python\n  name: python3\n---","key":"T2IgrkjmsC"}],"key":"C24bIW9K0J"},{"type":"block","kind":"notebook-content","data":{"tags":[]},"children":[{"type":"heading","depth":1,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Two Dimensional Dynamic Arrays","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Aw3lNDxJOl"}],"identifier":"two-dimensional-dynamic-arrays","label":"Two Dimensional Dynamic Arrays","html_id":"two-dimensional-dynamic-arrays","implicit":true,"key":"o2jlM7eYAw"}],"visibility":"show","key":"gENYpEtMNt"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Adapted from: “Object-Oriented Programming Using C++” by Ira Pohl (Addison- Wesley)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cgQTcXzupi"}],"key":"y8OajXf2Rx"}],"key":"oknwysRNYv"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Program that demonstrates dynamic arracy creation, manipulation and destruction in C++","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"uCPAE6UOIL"}],"identifier":"program-that-demonstrates-dynamic-arracy-creation-manipulation-and-destruction-in-c","label":"Program that demonstrates dynamic arracy creation, manipulation and destruction in C++","html_id":"program-that-demonstrates-dynamic-arracy-creation-manipulation-and-destruction-in-c","implicit":true,"key":"bBOCnZXK9Z"}],"key":"B4pV7lv8dF"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"c++","value":"// Dynamic arrays in two dimensions\n#include <iostream>\nusing namespace std;\n\nstruct twod {\n    double **   base;\n    int         row_size, column_size;\n};\n\nvoid allocate (int r, int s, twod & m)\n{\n    m.base = new double * [s];\n    for (int i = 0; i < s; ++i)\n        m.base[i] = new double[r];\n    m.row_size = r;\n    m.column_size = s;\n}\n\nvoid deallocate(twod & m)\n{\n    for (int i = 0; i < m.column_size; ++i)\n        delete [] m.base[i];\n    delete [] m.base;\n    m.row_size = 0;\n    m.column_size = 0;\n}\n\ndouble find_max(const twod & m)\n{\n    int i, j;\n    double max = m.base[0][0];\n\n    for (i = 0; i < m.column_size; ++i)\n        for (j = 0; j < m.row_size; ++j)\n            if (m.base[i][j] > max)\n                max = m.base[i][j];\n    return (max);\n}\n\nint main ()\n{\n    twod    a, b;\n    int     i, j;\n\n    allocate(2, 3, a);\n    allocate(4, 6, b);\n\n    for (i = 0; i < a.column_size; ++i)\n        for (j = 0; j < b.row_size; ++j)\n            a.base[i][j] = i * j;\n    \n    for (i = 0; i < b.column_size; ++i)\n        for (j = 0; j < b.row_size; ++j)\n            b.base[i][j] = i * j;\n\n    cout << find_max(a) << \" max in size 2 * 3\\n\";\n    cout << find_max(b) << \" max in size 4 * 6\\n\";\n}","position":{"start":{"line":1,"column":1},"end":{"line":60,"column":1}},"key":"aKtNCItlQB"}],"key":"fEZbn81AhR"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"y7MiGRpQH7"}],"key":"jRVM9VfhJG"}],"key":"z3ftQ7WVrN"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"shDEzZzke0"},{"type":"outputs","id":"MbcQdQo5UShaejrf3OcYQ","children":[],"key":"hS5x7H7sqM"}],"key":"Iyq9tsymGK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Cpp_Code/Chapter_4_8_Two_Dimensional_Dynamic_Arrays\"","key":"r88EcY2gHH"},{"type":"outputs","id":"Me8J6wrilFid5XcmMJa00","children":[],"key":"SvzA5QyMwx"}],"key":"jjm9NT6TFe"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"ea10RnvK7r"},{"type":"outputs","id":"aFfP5Gme5Y4Us5ATlHq4k","children":[],"key":"Slar1qdEi1"}],"key":"wFW01JIk3w"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ array_2d.cpp -w -o array_2d\")","key":"bfmW7nhUfB"},{"type":"outputs","id":"SYYGBgVmSmGfbptqTXftR","children":[],"key":"TGEprTJvNE"}],"key":"hAKprIyqv0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"exec_status = os.system(\"./array_2d\")","key":"aA7mdqbRoC"},{"type":"outputs","id":"UZ13RcWp4zeJC_zRmvrsG","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"2 max in size 2 * 3\n15 max in size 4 * 6\n"},"children":[],"key":"YL2vvQIGqv"}],"key":"OSKhQvjSXp"}],"key":"QsOl26PEAW"}],"key":"GlINiDWXGm"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Bit Fields","url":"/sections/computer-programming/cpp/object-oriented-programming-using-cpp/chapter-4-7-bit-fields","group":"Computer Programming"},"next":{"title":"Chapter 5: Data Hiding and Member Functions","url":"/sections/computer-programming/cpp/object-oriented-programming-using-cpp/object-oriented-programming-using-cpp-ch-5","group":"Computer Programming"}}},"domain":"http://localhost:3001"}