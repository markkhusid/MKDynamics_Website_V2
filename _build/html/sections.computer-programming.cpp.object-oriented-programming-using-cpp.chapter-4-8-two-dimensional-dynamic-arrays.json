{"version":3,"kind":"Notebook","sha256":"12d4e974c7dc42b557f3301c872557f731b944833c9a7b186ac46f3e77210351","slug":"sections.computer-programming.cpp.object-oriented-programming-using-cpp.chapter-4-8-two-dimensional-dynamic-arrays","location":"/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_4_8_Two_Dimensional_Dynamic_Arrays.ipynb","dependencies":[],"frontmatter":{"title":"Two Dimensional Dynamic Arrays","content_includes_title":true,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Mark Khusid","given":"Mark","family":"Khusid"},"name":"Mark Khusid","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/markkhusid/MKDynamics_Website_V2","numbering":{"title":{"offset":5}},"source_url":"https://github.com/markkhusid/MKDynamics_Website_V2/blob/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_4_8_Two_Dimensional_Dynamic_Arrays.ipynb","edit_url":"https://github.com/markkhusid/MKDynamics_Website_V2/edit/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_4_8_Two_Dimensional_Dynamic_Arrays.ipynb","exports":[{"format":"ipynb","filename":"Chapter_4_8_Two_Dimensional_Dynamic_Arrays.ipynb","url":"/build/Chapter_4_8_Two_Dime-dc82b2d328b3ca2836a95bd869c6c52e.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"","value":"---\njupytext:\n  formats: md:myst\n  text_representation:\n    extension: .md\n    format_name: myst\nkernelspec:\n  display_name: Python 3\n  language: python\n  name: python3\n---","key":"wTX27e7tXS"}],"key":"kqbx3XzfUs"},{"type":"block","kind":"notebook-content","data":{"tags":[]},"children":[{"type":"heading","depth":1,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Two Dimensional Dynamic Arrays","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"KNshzQvicy"}],"identifier":"two-dimensional-dynamic-arrays","label":"Two Dimensional Dynamic Arrays","html_id":"two-dimensional-dynamic-arrays","implicit":true,"key":"NaEc4OIE11"}],"visibility":"show","key":"GlGznPF76P"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Adapted from: “Object-Oriented Programming Using C++” by Ira Pohl (Addison- Wesley)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"b3Wq2TRRYl"}],"key":"kcpFaItL8I"}],"key":"KXRuIwGHEK"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Program that demonstrates dynamic arracy creation, manipulation and destruction in C++","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"CKvKgfhIMe"}],"identifier":"program-that-demonstrates-dynamic-arracy-creation-manipulation-and-destruction-in-c","label":"Program that demonstrates dynamic arracy creation, manipulation and destruction in C++","html_id":"program-that-demonstrates-dynamic-arracy-creation-manipulation-and-destruction-in-c","implicit":true,"key":"GSkmJTxnSS"}],"key":"bAjMPMgmqz"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"c++","value":"// Dynamic arrays in two dimensions\n#include <iostream>\nusing namespace std;\n\nstruct twod {\n    double **   base;\n    int         row_size, column_size;\n};\n\nvoid allocate (int r, int s, twod & m)\n{\n    m.base = new double * [s];\n    for (int i = 0; i < s; ++i)\n        m.base[i] = new double[r];\n    m.row_size = r;\n    m.column_size = s;\n}\n\nvoid deallocate(twod & m)\n{\n    for (int i = 0; i < m.column_size; ++i)\n        delete [] m.base[i];\n    delete [] m.base;\n    m.row_size = 0;\n    m.column_size = 0;\n}\n\ndouble find_max(const twod & m)\n{\n    int i, j;\n    double max = m.base[0][0];\n\n    for (i = 0; i < m.column_size; ++i)\n        for (j = 0; j < m.row_size; ++j)\n            if (m.base[i][j] > max)\n                max = m.base[i][j];\n    return (max);\n}\n\nint main ()\n{\n    twod    a, b;\n    int     i, j;\n\n    allocate(2, 3, a);\n    allocate(4, 6, b);\n\n    for (i = 0; i < a.column_size; ++i)\n        for (j = 0; j < b.row_size; ++j)\n            a.base[i][j] = i * j;\n    \n    for (i = 0; i < b.column_size; ++i)\n        for (j = 0; j < b.row_size; ++j)\n            b.base[i][j] = i * j;\n\n    cout << find_max(a) << \" max in size 2 * 3\\n\";\n    cout << find_max(b) << \" max in size 4 * 6\\n\";\n}","position":{"start":{"line":1,"column":1},"end":{"line":60,"column":1}},"key":"KzSyy703Vg"}],"key":"TVfESP0P7k"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NZPD7S7gci"}],"key":"c2150POdiw"}],"key":"kRbCSkCcd9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"JTk4qRFXiS"},{"type":"outputs","id":"YgzVKNnSdofI5wzzyKSxG","children":[],"key":"BWR1BjKj7G"}],"key":"N7UgzFJG0N"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Cpp_Code/Chapter_4_8_Two_Dimensional_Dynamic_Arrays\"","key":"BehjpsQknc"},{"type":"outputs","id":"rnYTgzlLZpa6eV1H-Q3ab","children":[],"key":"iNl38SIXQD"}],"key":"cvVquKr01s"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"kIXArXWY9Q"},{"type":"outputs","id":"KQFnf9jluZ-hX04IuUntN","children":[],"key":"HgYoK9SmZM"}],"key":"ytfoh4v79x"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ array_2d.cpp -w -o array_2d\")","key":"JMvQTUrOR9"},{"type":"outputs","id":"es5DTJ86xhPkz3wOa7Gpx","children":[],"key":"vTd71kKA39"}],"key":"FjHLtgLDbu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"exec_status = os.system(\"./array_2d\")","key":"oKWx9LGTyH"},{"type":"outputs","id":"kxVvPNiDamSvJeaF3t27Q","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"2 max in size 2 * 3\n15 max in size 4 * 6\n"},"children":[],"key":"Mk1c1e98Od"}],"key":"HGZkDIF9Ph"}],"key":"yLZzqncGYe"}],"key":"nWYkYqYBzw"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Bit Fields","url":"/sections/computer-programming/cpp/object-oriented-programming-using-cpp/chapter-4-7-bit-fields","group":"Computer Programming"},"next":{"title":"Chapter 5: Data Hiding and Member Functions","url":"/sections/computer-programming/cpp/object-oriented-programming-using-cpp/object-oriented-programming-using-cpp-ch-5","group":"Computer Programming"}}},"domain":"http://localhost:3003"}