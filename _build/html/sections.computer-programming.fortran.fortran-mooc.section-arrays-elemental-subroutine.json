do i = 1, 3\n        print '(*(F7.2))', B(i, :)\n    end do\n\n    print '(A)', 'C'\n    do i = 1, 3\n        print '(*(F7.2))', C(i, :)\n    end do\n\ncontains\n\n    elemental subroutine compute(A, B, C)\n        implicit none\n        real, intent(in) :: A\n        real, intent(out) :: B\n        real, intent(out) :: C\n\n        B = 2*A\n        C = 3*A\n    end subroutine compute\n\nend program elemental_subroutine","position":{"start":{"line":1,"column":1},"end":{"line":37,"column":1}},"key":"FKm9jnSdOq"}],"key":"L64Q4YrTjS"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kB7igY9pPn"}],"key":"bptBgBJLXg"}],"key":"Bz7Lcv10R6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"bB02JMQfZ3"},{"type":"outputs","id":"ZGqNL2ZTqwjqfI1-_4sEX","children":[],"key":"rxg2pxXPH4"}],"key":"lpitVzl0lm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Fortran_Code/Section_Arrays_Elemental_Subroutine\"","key":"aU4BtaPIgx"},{"type":"outputs","id":"55jbEyaqb5D7B8fiNV19C","children":[],"key":"c0sfTNn7gz"}],"key":"xf7EddvCkB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"iVNvfe0plY"},{"type":"outputs","id":"OS3f0xIH2A2LDTrdg4FmD","children":[],"key":"VVVrOe8eVg"}],"key":"eZSbhcha0Q"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_status = os.system(\"fpm build 2>/dev/null\")","key":"E78Zxg9NXO"},{"type":"outputs","id":"cn6q2MvCCrnJMAGiyzosK","children":