{"version":3,"kind":"Notebook","sha256":"fb70d89d8b746eff42cceceefb525bdd15b67da4b90af7c846c7cb0a2eaca089","slug":"sections.computer-programming.cpp.object-oriented-programming-using-cpp.chapter-2-3-program-structure","location":"/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_2_3_Program_Structure.ipynb","dependencies":[],"frontmatter":{"title":"Chapter 2.3: Program Structure","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3.9.2 64-bit","language":"python"},"authors":[{"nameParsed":{"literal":"Mark Khusid","given":"Mark","family":"Khusid"},"name":"Mark Khusid","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/markkhusid/MKDynamics_Website_V2","numbering":{"title":{"offset":5}},"source_url":"https://github.com/markkhusid/MKDynamics_Website_V2/blob/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_2_3_Program_Structure.ipynb","edit_url":"https://github.com/markkhusid/MKDynamics_Website_V2/edit/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_2_3_Program_Structure.ipynb","exports":[{"format":"ipynb","filename":"Chapter_2_3_Program_Structure.ipynb","url":"/build/Chapter_2_3_Program_-9d2a0d7b52bb99ff8b94b5e53cb203ce.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Adapted from: “Object-Oriented Programming Using C++” by Ira Pohl (Addison- Wesley)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"rpJYUtGdkP"}],"key":"bdLtgSosXl"}],"key":"XOJQ1YunJ6"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Program that demonstrates program structure in C++","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"z9YQqDZTkt"}],"identifier":"program-that-demonstrates-program-structure-in-c","label":"Program that demonstrates program structure in C++","html_id":"program-that-demonstrates-program-structure-in-c","implicit":true,"key":"f50KyvN2IS"}],"key":"kjHHjdcZc4"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"cpp","value":"// Greatest common divisor program.\n#include <iostream>\n#include <assert.h>\n\nint gcd(int m, int n)   // function declartion\n{                       // block\n    int r;              // declaration of remainder\n\n    while (n != 0) {    // not equal\n        r = m % n;      // modulo operator\n        m = n;          // assignment\n        n = r;\n    }                   // end while loop\n\n    return m;           // exit gcd with value m\n}\n\nint main()\n{\n    int x, y, g;\n\n    std::cout << \"\\nProgram GCD C++\";\n    do {\n        std::cout << \"\\nEnter two integers: \";\n        std::cin >> x >> y;\n        assert(x * y != 0); // precondition on GCD\n        std::cout << \"\\nGCD(\" << x << \", \" << y << \") = \"\n             << (g = gcd(x, y)) << std::endl;\n        assert(x % g == 0 && y % g ==0); // postcondition\n    } while (x != y);\n}","key":"mXqTiYk8Hy"}],"key":"rX1vPhSkbu"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Compile and Execute the Program","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"yKC0eYLi3a"}],"identifier":"compile-and-execute-the-program","label":"Compile and Execute the Program","html_id":"compile-and-execute-the-program","implicit":true,"key":"uOuMbjEmiS"}],"key":"xGIYDyva3i"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"d0E6HLaFsU"}],"key":"B8MvVaLRur"}],"key":"QLtmhKg0xb"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"k3w5TBMG2q"},{"type":"outputs","id":"1oXIsySn0i68HtkUS69rt","children":[],"key":"Sjlu7ICDDu"}],"key":"DFUCmGLIMg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Cpp_Code/Chapter_2_3_Program_Stucture\"","key":"grJUBDiwax"},{"type":"outputs","id":"3PdCVrrmJDFw5wcEAM3qk","children":[],"key":"xSA6MqCKSl"}],"key":"sHb6sDyARy"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ch_dir_stat = os.chdir(code_dir)","key":"zSdKlNX4kV"},{"type":"outputs","id":"Uc9LYQy1XMbVYaRHa5ev4","children":[],"key":"kBhyc8oOAL"}],"key":"D7r7qzWX5L"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ gcd.cpp -w -o gcd\")","key":"PcrGAjmMRq"},{"type":"outputs","id":"Soa2bfmsVGf2ExjN5rHCL","children":[],"key":"s19wZSglde"}],"key":"iuEhatDJA5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"exec_status = os.system(\"echo \\\"20 10 50 4 60 30 100 100\\\" | ./gcd\")","key":"zwSltB90RU"},{"type":"outputs","id":"wGHWK0f0TxZTKkDFPcbrh","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"\nProgram GCD C++\nEnter two integers: \nGCD(20, 10) = 10\n\nEnter two integers: \nGCD(50, 4) = 2\n\nEnter two integers: \nGCD(60, 30) = 30\n\nEnter two integers: \nGCD(100, 100) = 100\n"},"children":[],"key":"u36k23fNtF"}],"key":"XaMwB8QMop"}],"key":"nqI8A2UzXP"}],"key":"YRPBDzCQbW"},"references":{"cite":{"or