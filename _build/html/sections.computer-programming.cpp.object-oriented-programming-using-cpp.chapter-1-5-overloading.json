{"version":3,"kind":"Notebook","sha256":"e37d31cd8a6baced5381def31b3a538709fae1bac180aca85a5330632cfb05ce","slug":"sections.computer-programming.cpp.object-oriented-programming-using-cpp.chapter-1-5-overloading","location":"/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_1_5_Overloading.ipynb","dependencies":[],"frontmatter":{"title":"Chapter 1.5: Overloading the “+” Operator to Handle Strings","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Mark Khusid","given":"Mark","family":"Khusid"},"name":"Mark Khusid","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/markkhusid/MKDynamics_Website_V2","numbering":{"title":{"offset":5}},"source_url":"https://github.com/markkhusid/MKDynamics_Website_V2/blob/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_1_5_Overloading.ipynb","edit_url":"https://github.com/markkhusid/MKDynamics_Website_V2/edit/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_1_5_Overloading.ipynb","exports":[{"format":"ipynb","filename":"Chapter_1_5_Overloading.ipynb","url":"/build/Chapter_1_5_Overload-8bd6ca361ee81bb64d17fbb8c2575af6.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Adapted from: “Object-Oriented Programming Using C++” by Ira Pohl (Addison- Wesley)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"eJWI3VsJOp"}],"key":"uHdm24AP46"}],"key":"hOXoxIlxGV"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Program that demonstrates operator overloading in C++","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qZjeEP5jbR"}],"identifier":"program-that-demonstrates-operator-overloading-in-c","label":"Program that demonstrates operator overloading in C++","html_id":"program-that-demonstrates-operator-overloading-in-c","implicit":true,"key":"t3PDIB62ya"}],"key":"HK0z5HclUR"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"cpp","value":"// Overloading the operator +\n#include <iostream>\n#include <string>\n#include <cstring>\n\nusing namespace std;\n\nclass my_string {\n    public:\n        my_string() { \n            len = 0; s = new char[1]; \n        }\n\n        explicit my_string(int n) {\n            s = new char[n+1];\n            len = n;\n        }\n\n        void assign(const char* str)\n        {\n            delete []s;\n            len = strlen(str);\n            s = new char[len + 1];\n            strcpy(s, str);\n        }\n\n        int length() const {\n            return len;\n        }\n\n        void print() const {\n            cout << s << \"\\nLength: \" << len << endl;\n        }\n\n        friend my_string& operator+ (const my_string& a, const my_string& b);\n    \n    private:\n        char* s;\n        int len;\n};\n\n// Overload +\nmy_string& operator+(const my_string& a, const my_string& b)\n{\n    my_string* temp = new my_string(a.len + b.len);\n\n    strcpy(temp->s, a.s);\n    strcat(temp->s, b.s);\n    return *temp;\n}\n\nvoid print(const char* c) // file scope print\n{\n    cout << c << \"\\nLength: \" << strlen(c) << endl;\n}\n\nint main()\n{\n    my_string one, two, both;\n    char three[40] = {\"My name is Charles Babbage.\"};\n\n    one.assign(\"My name is Alan Turing.\");\n    two.assign(three);\n    print(three);   // file scope print called\n\n    if (one.length() <= two.length())\n        one.print();\n    else\n        two.print();\n\n    both = one + two;\n\n    both.print();\n}","key":"a5M4DrBkqA"}],"key":"WW0MsLKwVm"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Compile and Execute the Program","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"g21h2JVVzw"}],"identifier":"compile-and-execute-the-program","label":"Compile and Execute the Program","html_id":"compile-and-execute-the-program","implicit":true,"key":"m8aGoQZi95"}],"key":"bPtXFAgcoX"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"KC80zoGgPT"}],"key":"einDT1dVKx"}],"key":"VTB3ZR0Zqt"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"zwwlyh8836"},{"type":"outputs","id":"mbzPDnNiatXhSrMKyZ5To","children":[],"key":"nKAwu6uonO"}],"key":"Ro6qbHaSFJ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Cpp_Code/Chapter_1_5_Overloading\"","key":"cVlytlj28V"},{"type":"outputs","id":"7jRNTQImsEIAgOFZnmTWH","children":[],"key":"O9xRmp8a2F"}],"key":"yDFl6JiFhZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"mdtLOoy6jV"},{"type":"outputs","id":"kd4tmDA6d5L21HUV36YvK","children":[],"key":"j0GRWjvcdQ"}],"key":"PQ8bZ9nGIE"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ string4.cpp -w -o string4\")","key":"o0eh4RyWi3"},{"type":"outputs","id":"rfmtpx9do-wFXjQGq-3FO","children":[],"key":"hF86rTGp9G"}],"key":"k7tK7MyD6G"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"exec_status = os.system(\"./string4\")","key":"kv0n6IZHST"},{"type":"outputs","id":"KqMPcJnIlhNG4yIm7fvbX","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"My name is Charles Babbage.\nLength: 27\nMy name is Alan Turing.\nLength: 23\nMy name is Alan Turing.My name is Charles Babbage.\nLength: 50\n"},"children":[],"key":"dSAS40ffSl"}],"key":"RuXvXA5egO"}],"key":"RYj0Du1nO4"}],"key":"j1hn7hcme8"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Hello World!","url":"/sections/computer-programming/cpp/object-oriented-programming-using-cpp/hello-cpp","group":"Computer Programming"},"next":{"title":"Chapter 1.7: The C++ Standard Template Library","url":"/sections/computer-programming/cpp/object-oriented-programming-using-cpp/chapter-1-7-the-standard-template-library","group":"Computer Programming"}}},"domain":"http://localhost:3001"}