{"version":3,"kind":"Notebook","sha256":"e37d31cd8a6baced5381def31b3a538709fae1bac180aca85a5330632cfb05ce","slug":"sections.computer-programming.cpp.object-oriented-programming-using-cpp.chapter-1-5-overloading","location":"/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_1_5_Overloading.ipynb","dependencies":[],"frontmatter":{"title":"Chapter 1.5: Overloading the “+” Operator to Handle Strings","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Mark Khusid","given":"Mark","family":"Khusid"},"name":"Mark Khusid","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/markkhusid/MKDynamics_Website_V2","numbering":{"title":{"offset":5}},"source_url":"https://github.com/markkhusid/MKDynamics_Website_V2/blob/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_1_5_Overloading.ipynb","edit_url":"https://github.com/markkhusid/MKDynamics_Website_V2/edit/main/Sections/Computer_Programming/CPP/Object_Oriented_Programming_Using_Cpp/Chapter_1_5_Overloading.ipynb","exports":[{"format":"ipynb","filename":"Chapter_1_5_Overloading.ipynb","url":"/build/Chapter_1_5_Overload-8bd6ca361ee81bb64d17fbb8c2575af6.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Adapted from: “Object-Oriented Programming Using C++” by Ira Pohl (Addison- Wesley)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ilk5LYUoIA"}],"key":"bGIYYqujRg"}],"key":"DhEzXt42MR"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Program that demonstrates operator overloading in C++","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"c0DsdVGrvj"}],"identifier":"program-that-demonstrates-operator-overloading-in-c","label":"Program that demonstrates operator overloading in C++","html_id":"program-that-demonstrates-operator-overloading-in-c","implicit":true,"key":"w7flXsJ4VT"}],"key":"p4hb3iNxxc"},{"type":"block","kind":"notebook-content","children":[{"type":"code","lang":"cpp","value":"// Overloading the operator +\n#include <iostream>\n#include <string>\n#include <cstring>\n\nusing namespace std;\n\nclass my_string {\n    public:\n        my_string() { \n            len = 0; s = new char[1]; \n        }\n\n        explicit my_string(int n) {\n            s = new char[n+1];\n            len = n;\n        }\n\n        void assign(const char* str)\n        {\n            delete []s;\n            len = strlen(str);\n            s = new char[len + 1];\n            strcpy(s, str);\n        }\n\n        int length() const {\n            return len;\n        }\n\n        void print() const {\n            cout << s << \"\\nLength: \" << len << endl;\n        }\n\n        friend my_string& operator+ (const my_string& a, const my_string& b);\n    \n    private:\n        char* s;\n        int len;\n};\n\n// Overload +\nmy_string& operator+(const my_string& a, const my_string& b)\n{\n    my_string* temp = new my_string(a.len + b.len);\n\n    strcpy(temp->s, a.s);\n    strcat(temp->s, b.s);\n    return *temp;\n}\n\nvoid print(const char* c) // file scope print\n{\n    cout << c << \"\\nLength: \" << strlen(c) << endl;\n}\n\nint main()\n{\n    my_string one, two, both;\n    char three[40] = {\"My name is Charles Babbage.\"};\n\n    one.assign(\"My name is Alan Turing.\");\n    two.assign(three);\n    print(three);   // file scope print called\n\n    if (one.length() <= two.length())\n        one.print();\n    else\n        two.print();\n\n    both = one + two;\n\n    both.print();\n}","key":"kl5rABK2JN"}],"key":"XHSR4qZCkM"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Compile and Execute the Program","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kvB0UB6ZF6"}],"identifier":"compile-and-execute-the-program","label":"Compile and Execute the Program","html_id":"compile-and-execute-the-program","implicit":true,"key":"PZsZM5EVFD"}],"key":"UuGbD9p3dO"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Gnu Compiler Collection (g++):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cKwq4ysgk3"}],"key":"Dc5wqcgVRP"}],"key":"qWurG75poi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = os.getcwd()","key":"GnRU6M6TAu"},{"type":"outputs","id":"B5ZWC5lbl0Mf0PpnI7GwC","children":[],"key":"yUyJqHU4MF"}],"key":"nRgmwgpt3P"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"code_dir = root_dir + \"/\" + \"Cpp_Code/Chapter_1_5_Overloading\"","key":"lZpBBUhVoB"},{"type":"outputs","id":"KIAiL9-0BcYdnV3LXOvFT","children":[],"key":"zdJFWfjysh"}],"key":"zpT6KBneXK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"os.chdir(code_dir)","key":"IrHZ5hptQR"},{"type":"outputs","id":"PzZKCTv3NY7DfBnngts43","children":[],"key":"zSfqy8Yy4t"}],"key":"IV6c116ero"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"build_command = os.system(\"g++ string4.cpp -w -o string4\")","key":"ISIfPQFhVh"},{"type":"outputs","id":"hPoj0g4vmoAGmKlZbW_qr","children":[],"key":"pwFM8UMJqf"}],"key":"AmHob3iYVV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"exec_status = os.system(\"./string4\")","key":"NfQ42RzeiK"},{"type":"outputs","id":"4z5rk7AHkBDhlsze-jiBy","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"My name is Charles Babbage.\nLength: 27\nMy name is Alan Turing.\nLength: 23\nMy name is Alan Turing.My name is Charles Babbage.\nLength: 50\n"},"children":[],"key":"ZQZw1Eoinb"}],"key":"R1qO7IxQ7v"}],"key":"KDDiGAcPQq"}],"key":"W4DkeJBIJ2"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Hello World!","url":"/sections/computer-programming/cpp/object-oriented-programming-using-cpp/hello-cpp","group":"Computer Programming"},"next":{"title":"Chapter 1.7: The C++ Standard Template Library","url":"/sections/computer-programming/cpp/object-oriented-programming-using-cpp/chapter-1-7-the-standard-template-library","group":"Computer Programming"}}},"domain":"http://localhost:3003"}