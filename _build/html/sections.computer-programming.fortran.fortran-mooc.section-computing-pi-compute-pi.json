4,79.3,68.167,158.7,102.5,238c34.3,79.3,51.8,119.3,52.5,120\nc340,-704.7,510.7,-1060.3,512,-1067\nl0 -0\nc4.7,-7.3,11,-11,19,-11\nH40000v40H1012.3\ns-271.3,567,-271.3,567c-38.7,80.7,-84,175,-136,283c-52,108,-89.167,185.3,-111.5,232\nc-22.3,46.7,-33.8,70.3,-34.5,71c-4.7,4.7,-12.3,7,-23,7s-12,-1,-12,-1\ns-109,-253,-109,-253c-72.7,-168,-109.3,-252,-110,-252c-10.7,8,-22,16.7,-34,26\nc-22,17.3,-33.3,26,-34,26s-26,-26,-26,-26s76,-59,76,-59s76,-60,76,-60z\nM1001 80h400000v40h-400000z'/></svg></span></span></span><span class=\"vlist-s\">​</span></span><span class=\"vlist-r\"><span class=\"vlist\" style=\"height:0.1795em;\"><span></span></span></span></span></span><span class=\"mord mathnormal sizing reset-size6 size8\">d</span><span class=\"mord mathnormal sizing reset-size6 size8\">x</span></span></span></span></span>","enumerator":"1","key":"MxtQe2JiGa"}],"key":"E5EIpOsrPk"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"In file section_computing_pi_compute_pi.f90","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Dwzb8OJ4fq"}],"identifier":"in-file-section-computing-pi-compute-pi-f90","label":"In file section_computing_pi_compute_pi.f90","html_id":"in-file-section-computing-pi-compute-pi-f90","implicit":true,"key":"WYCZIoFCsd"}],"key":"zRJDYZ3GaE"},{"type":"block","kind":"notebook-content","children":[{"type":"include","file":"Fortran_Code/Section_Computing_Pi_Compute_Pi/app/section_computing_pi_compute_pi.f90","literal":true,"children":[{"type":"code","value":"program compute_pi\n    use, intrinsic :: iso_fortran_env, only : DP => REAL64, I8 => INT64\n    implicit none\n    integer(kind=I8) :: i, nr_iters\n    real(kind=DP) :: delta, x, pi_val\n    real(kind=DP) :: pi_val_actual\n\n    pi_val = 0.0_DP\n    pi_val_actual = 2.0_DP * acos(0.0_DP)\n    nr_iters = get_nr_iters()\n    delta = 1.0_DP/nr_iters\n    x = 0.0_DP\n    do i = 1, nr_iters\n        pi_val = pi_val + sqrt(1.0_DP - x**2)\n        x = x + delta\n    end do\n    pi_val = 4.0_DP*pi_val/nr_iters\n    print '(A, I10, A, F25.15)', \"After \", nr_iters, \" loops, Pi = \", pi_val\n    print '(A, F25.15)', \"Actual value of Pi = \", pi_val_actual\n    print '(A, F25.15)', \"Absolute difference = \", abs(pi_val - pi_val_actual)\n\ncontains\n     \n    function get_nr_iters() result(nr_iters)\n        use, intrinsic :: iso_fortran_env, only : error_unit\n        implicit none\n        integer(kind=I8) :: nr_iters\n        integer(kind=I8), parameter :: default_nr_iters = 1000_I8\n        character(len=1024) :: buffer, msg\n        integer :: istat\n\n        if (command_argument_count() >= 1) then\n            call get_command_argument(1, buffer)\n            read (buffer, fmt=*, iostat=istat, iomsg=msg) nr_iters\n            if (istat /= 0) then\n                write (unit=error_unit, fmt='(2A)') &\n                    'error: ', msg\n                stop 1\n            end if\n        else\n            nr_iters = default_nr_iters\n        end if\n    end function get_nr_iters\n\nend program compute_pi\n","lang":"fortran","filename":"section_computing_pi_compute_pi.f90","key":"dQUyGpWe1q"}],"key":"YqPiY0JJld"}],"key":"HzhfkqTbxv"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ZaC5hTQGXJ"}],"key":"rsF7FkW713"}],"key":"VHPzT0qyHf"},{"type":"block","kind":"notebook-content","data":{"tags":[]},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Build the Program using FPM (Fortran Package Manager)","position":{"start":{"line":1,"colu