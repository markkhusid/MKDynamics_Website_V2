tor2\n\n  vector2 = 0.0\n  call scopy(size(vector1), vector1, 2, vector2, 2)\n  print '(A20, *(F5.1))', 'copy N 2 2: ', vector2\n\n  large_vector = 0.0\n  call scopy(size(vector1), vector1, 1, large_vector, 2)\n  print '(A20, *(F5.1))', 'copy N 1 2: ', large_vector\n  call scopy(size(vector1), 3.0*vector1, 1, large_vector(2), 2)\n  print '(A20, *(F5.1))', 'shift copy N 1 2: ', large_vector\n\nend program copy_test\n","lang":"fortran","filename":"section_blas_lapack_copy.f90","key":"LvHHSduAFJ"}],"key":"J0fy1406Ju"}],"key":"Dk1W8lWcei"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The above program is compiled and run using Fortran Package Manager (fpm):","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"eUp700iWBC"}],"key":"XOCscytbOv"}],"key":"KeyE3JDjdp"},{"type":"block","kind":"notebook-content","data":{"tags":[]},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Build the Program using FPM (Fortran Package Manager)","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"uyvuTbMIP9"}],"identifier":"build-the-program-using-fpm-fortran-package-manager","label":"Build the Program using FPM (Fortran Package Manager)","html_id":"build-the-program-using-fpm-fortran-package-manager","implicit":true,"key":"Ym0m6BctR6"}],"visibility":"show","key":"XdQn7btRKY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import os\nroot_dir = \"\"\nroot_dir = os.getcwd()","key":"NNlEHXGykw"},{"type":"outputs","id":"Q-V37fhVFZoxezUu6iYHD","children":[],"key":"nadh0rOIt6"}],"key":"pVqdRfyut8"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{